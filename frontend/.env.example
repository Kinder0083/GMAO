# Configuration GMAO Iris Frontend

# URL du backend API
# En local: http://localhost:8001
# En production: https://api.votre-domaine.com
REACT_APP_BACKEND_URL=http://localhost:8001

# Configuration serveur de développement
HTTPS=false
PORT=3000

# Fonctionnalités
REACT_APP_ENABLE_VISUAL_EDITS=true
ENABLE_HEALTH_CHECK=false
